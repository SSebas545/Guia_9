#include <stdio.h>
#include <stdlib.h>
#include <time.h>

int main()
{
    int numsec, intento, i;

    srand(time(NULL));
    numsec = rand() % 100;

    for(i = 1; i <= 10; i++)
    {
        printf("Intento %d: ", i);
        scanf("%d", &intento);

        if(intento == numsec)
        {
            printf("¡Acertaste en %d intentos!\n", i);
            return 0;
        }
        else if(intento < numsec)
        {
            printf("El numero es mayor\n");
        }
        else
        {
            printf("El numero es menor\n");
        }
    }

    printf("No acertaste. El numero era %d\n", numsec);

    return 0;
}
