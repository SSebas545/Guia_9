#include <stdio.h>

int main()
{
    int n, i;
    char opcion;

    do
    {
        do
        {
            printf("Ingrese un numero entre 1 y 9\n");
            scanf("%d", &n);
        } while(n < 1 || n > 9);

        for(i = 1; i <= 9; i++)
        {
            printf("%dX%d=%d\n", n, i, n*i);
        }

        printf("¿Quieres introducir otro numero? S/N\n");
        scanf(" %c", &opcion);

    } while(opcion == 'S' || opcion == 's');

    printf("Gracias por usar nuestro programa\n");

    return 0;
}
