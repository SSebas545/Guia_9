#include <stdio.h>

int main()
{
    int n, i, j;

    do
    {
        printf("Ingrese un numero positivo\n");
        scanf("%d", &n);
    } while(n < 0);

    for(i = n; i >= 1; i--)
    {
        for(j = 1; j <= i; j++)
        {
            printf("%d", j);
        }
        printf("\n");
    }

    return 0;
}
