#include <stdio.h>

int main()
{
    int a, b, i, sumaA = 0, sumaB = 0;

    printf("Ingrese dos numeros\n");
    scanf("%d %d", &a, &b);

    for(i = 1; i < a; i++)
    {
        if(a % i == 0) sumaA += i;
    }

    for(i = 1; i < b; i++)
    {
        if(b % i == 0) sumaB += i;
    }

    if(sumaA == b && sumaB == a)
    {
        printf("Son amigos\n");
    }
    else
    {
        printf("No son amigos\n");
    }

    return 0;
}
